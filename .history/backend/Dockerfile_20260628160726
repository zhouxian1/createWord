# === 构建阶段 ===
FROM python:3.11-alpine AS builder

WORKDIR /app

# 构建依赖
RUN apk add --no-cache \
    build-base \
    postgresql-dev \
    musl-dev

# 安装Python依赖到独立目录
COPY requirements.txt .
RUN pip install --no-cache-dir --prefix=/install -r requirements.txt -i https://pypi.tuna.tsinghua.edu.cn/simple

# === 运行阶段 ===
FROM python:3.11-alpine

WORKDIR /app

# 仅安装运行时依赖（无build-base，极小）
RUN apk add --no-cache \
    libpq \
    wget \
    curl

# 从构建阶段复制已编译的Python包
COPY --from=builder /install /usr/local

# 应用代码
COPY . .

# 创建数据目录
RUN mkdir -p /app/data/uploads /app/data/vector_db /app/data/inverted_index

# 环境变量
ENV FLASK_ENV=production
ENV PYTHONUNBUFFERED=1

EXPOSE 5000

# 使用gunicorn启动
CMD ["gunicorn", "--bind", "0.0.0.0:5000", "--workers", "4", "--timeout", "120", "--access-logfile", "-", "run:app"]
