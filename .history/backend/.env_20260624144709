# ===== 基础配置 =====
FLASK_ENV=development
SECRET_KEY=doc-gen-system-secret-key-2024

# ===== 文件存储配置 =====
# 存储类型: minio / local
STORAGE_TYPE=minio

# MinIO配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=doc-gen-system
MINIO_SECURE=false

# ===== LLM配置 - 国产大模型 =====
# 模型提供商: qwen / deepseek / chatglm / local
LLM_PROVIDER=qwen

# 千问(DashScope API)配置
# 注册地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your-dashscope-api-key-here
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your-dashscope-api-key-here
LLM_MODEL=qwen-plus

# DeepSeek配置（如使用DeepSeek，取消注释）
# LLM_PROVIDER=deepseek
# LLM_API_BASE=https://api.deepseek.com/v1
# LLM_API_KEY=your-deepseek-api-key-here
# LLM_MODEL=deepseek-chat

# 本地模型部署配置（vLLM/Ollama）
# LLM_PROVIDER=local
# LOCAL_LLM_HOST=localhost
# LOCAL_LLM_PORT=8000
# LOCAL_LLM_MODEL=Qwen2.5-14B-Instruct

# ===== Embedding模型配置 =====
# 默认使用中文优化模型
EMBEDDING_MODEL=shibing624/text2vec-base-chinese

# ===== 数据库配置 =====
# SQLite（默认）
# DATABASE_URL=sqlite:///data/dev.db
# PostgreSQL（生产环境推荐）
# DATABASE_URL=postgresql://user:password@localhost:5432/doc_gen
